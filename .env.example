# Token de tu Bot de Telegram (Obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Canal o Chat ID a donde enviar las noticias automáticamente (opcional, si es un canal público)
# Si quieres que el bot funcione solo por mensajes directos, puedes dejar esto vacío o configurarlo luego.
TELEGRAM_CHANNEL_ID=@tu_canal_likancenti

# Frecuencia de búsqueda de noticias en minutos
FETCH_INTERVAL_MINUTES=120

# Llave API gratuita de Groq (Consíguela en console.groq.com)
GROQ_API_KEY=tu_api_key_de_groq_aqui
