# Token de tu Bot de Telegram (Obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Canal o Chat ID a donde enviar las noticias automáticamente (opcional, si es un canal público)
# Si quieres que el bot funcione solo por mensajes directos, puedes dejar esto vacío o configurarlo luego.
TELEGRAM_CHANNEL_ID=@tu_canal_likancenti

# Frecuencia de búsqueda de noticias en minutos
FETCH_INTERVAL_MINUTES=120

# Llave API gratuita de Groq (Consíguela en console.groq.com)
# Puedes poner VARIAS claves separadas por coma para sumar cuotas free y rotar ante 429:
# GROQ_API_KEY=clave1,clave2,clave3
GROQ_API_KEY=tu_api_key_de_groq_aqui

# --- Cerebro: proveedores LLM free adicionales (todos opcionales, con rotación) ---
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
GROK_API_KEY=
# OpenRouter: una key da acceso a muchos modelos ':free' (openrouter.ai)
OPENROUTER_API_KEY=
# GitHub Models (free para cuentas GitHub): un token con scope models
GITHUB_MODELS_TOKEN=

# --- Clima (fallback; el primario Open-Meteo es gratis y no necesita key) ---
OPENWEATHER_API_KEY=

# --- Finanzas: snapshot de bolsa para el agente de voz (finnhub.io, free) ---
FINNHUB_API_KEY=

# --- Voz de salida (Edge-TTS, gratis). Voz neuronal en español, opcional ---
TTS_VOICE=es-MX-JorgeNeural

# --- Imágenes de portada en alertas globales (Pollinations, gratis). 1=on, 0=off ---
ENABLE_ALERT_IMAGES=1

# --- Caché persistente (Upstash Redis REST, capa gratis) para sobrevivir reinicios ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Base de datos (Supabase) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Pagos USDT (opcional, en testeo) ---
CRYPTOPAY_API_TOKEN=
USDT_WALLET=

# --- Anti-abuso / anti-bot (protege la capa gratis). Valores por defecto seguros ---
RATE_LIMIT_MSGS=5          # máx mensajes por ventana
RATE_LIMIT_PERIOD=60       # ventana en segundos
DAILY_MSG_LIMIT=300        # tope diario de mensajes por usuario (0 = sin tope)
VOICE_COOLDOWN_SECONDS=20  # segundos mínimos entre notas de voz
VOICE_DAILY_LIMIT=40       # máx notas de voz por usuario al día
